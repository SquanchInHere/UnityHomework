# Let Git auto-detect text files.
# On Windows with core.autocrlf=true:
# - repo stores LF
# - working copy can use CRLF
* text=auto

# C# / Unity scripts
*.cs text
*.shader text
*.cginc text
*.compute text
*.asmdef text
*.asmref text

# Common text/config files
*.json text
*.xml text
*.txt text
*.md text
*.yml text
*.yaml text
*.ini text
*.cfg text
*.conf text

# Unity YAML assets/scenes/prefabs/meta
*.unity text
*.prefab text
*.asset text
*.meta text
*.mat text
*.controller text
*.anim text
*.overrideController text
*.physicMaterial text
*.physicsMaterial2D text

# Scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text
*.sh text eol=lf

